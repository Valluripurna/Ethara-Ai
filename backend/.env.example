# Copy to .env locally. On Render, set these in the dashboard (Environment).

# MongoDB Atlas connection string (required in production)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend URL(s) for CORS — no trailing slash. Comma-separated for multiple:
# CLIENT_URL=http://localhost:3000,https://your-frontend.onrender.com
CLIENT_URL=http://localhost:3000

# Render injects PORT automatically; optional locally
# PORT=5000

